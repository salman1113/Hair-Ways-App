# ═══════════════════════════════════════════════════════════════════════════
#  Hair Ways — Production Environment Variables Template
#  Copy to .env and fill in real values. NEVER commit real secrets to Git.
# ═══════════════════════════════════════════════════════════════════════════

# ── Django Core ───────────────────────────────────────────────────────────
SECRET_KEY=<generate-a-strong-random-key>
DEBUG=False
ALLOWED_HOSTS=hairways.com,www.hairways.com
CORS_ALLOWED_ORIGINS=https://hairways.com,https://www.hairways.com

# ── Database (AWS RDS) ───────────────────────────────────────────────────
DB_NAME=hairways_db
DB_USER=postgres
DB_PASSWORD=<rds-password>
DB_HOST=<rds-endpoint>.ap-south-1.rds.amazonaws.com
DB_PORT=5432

# ── Redis (AWS ElastiCache) ──────────────────────────────────────────────
REDIS_HOST=<elasticache-endpoint>
REDIS_PORT=6379

# ── AWS S3 (Static & Media Storage) ──────────────────────────────────────
USE_S3=True
AWS_ACCESS_KEY_ID=<your-iam-access-key>
AWS_SECRET_ACCESS_KEY=<your-iam-secret-key>
AWS_STORAGE_BUCKET_NAME=hairways-assets
AWS_S3_REGION_NAME=ap-south-1

# ── Google Auth ──────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=<your-google-client-id>

# ── Email (SMTP) ─────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=<your-email>
EMAIL_HOST_PASSWORD=<your-app-password>
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False

# ── AI Engine (Groq) ────────────────────────────────────────────────────
GROQ_API_KEY=<your-groq-api-key>
