{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "PublicReadForStaticMedia",
      "Effect": "Allow",
      "Principal": "*",
      "Action": "s3:GetObject",
      "Resource": [
        "arn:aws:s3:::hairways-assets-hairways-assets-123/static/*",
        "arn:aws:s3:::hairways-assets-hairways-assets-123/media/*"
      ]
    }
  ]
}